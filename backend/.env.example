# Backend env — copy to ../.env.local (repo root) and fill in.
# The repo root .env.local is the single source of truth for backend + mobile.

DATABASE_URL=postgres://user:pass@host:5432/dbname
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

CLERK_SECRET_KEY=sk_
CLERK_WEBHOOK_SECRET=whsec_

STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

ELEVENLABS_API_KEY=sk_
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_DEFAULT_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

SENTRY_DSN_BACKEND=
SENTRY_RELEASE=
AXIOM_TOKEN=
AXIOM_DATASET=dunner-prod

APP_URL=https://api.dunner.app
DEEPLINK_SCHEME=dunner

PORT=3000
HOSTNAME=::

# --- Resend (waitlist + invite emails) ---------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Use a verified domain in prod. Default 'onboarding@resend.dev' only sends
# to your own email until you verify.
RESEND_FROM_EMAIL=Dunner <hello@dunner.xyz>
RESEND_REPLY_TO=hello@dunner.xyz

# --- Admin gate --------------------------------------------------------
# Comma-separated list of admin emails. Required at /admin/* (landing
# /admin re-checks too).
ADMIN_EMAILS=you@example.com

# --- Outbound links in emails ------------------------------------------
# Used by waitlist invite emails. Stays env-driven so we can swap APK
# hosting (GitHub Release vs S3 vs landing) without a deploy.
ANDROID_APK_URL=https://dunner.xyz/download
LANDING_URL=https://dunner.xyz
